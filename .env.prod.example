APP_NAME=QuizSystem
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.tld

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=quiz
DB_USERNAME=quiz_user
DB_PASSWORD=secure_password_here
DB_ROOT_PASSWORD=secure_root_password

MYSQL_ROOT_PASSWORD=secure_root_password
MYSQL_DATABASE=quiz
MYSQL_USER=quiz_user
MYSQL_PASSWORD=quiz_password
# Cache / Session / Queue
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

LOG_CHANNEL=stack
LOG_LEVEL=info

APP_TRUSTED_PROXIES=127.0.0.1,::1
SESSION_SECURE_COOKIE=true
