APP_NAME=QuizSystem
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.tld

# Database
DB_CONNECTION=pgsql
DATABASE_URL=postgresql://quiz_user:secure_password_here@your-postgres-host.render.com:5432/quiz?sslmode=require
# Cache / Session / Queue
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

LOG_CHANNEL=stack
LOG_LEVEL=info

APP_TRUSTED_PROXIES=127.0.0.1,::1
SESSION_SECURE_COOKIE=true
